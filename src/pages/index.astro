---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Futuristic Portfolio | Geovanny Peñaloza">
  <main>
    <section class="hero" data-theme="light">
      <button class="theme-toggle" aria-label="Toggle theme">
        <svg class="sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/>
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
        <svg class="moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      <div class="grid-bg"></div>

      <div class="content">
        <h1 class="glitch" data-text="GEOVANNY">
          <span class="line1">GEOVANNY</span>
          <span class="line2">PEÑALOZA</span>
        </h1>
        <p class="subtitle">Desarrollador Full Stack & Creador Digital</p>
        <div class="cta-container">
          <a href="/portfolio" class="cyber-btn disintegrate">
            <span class="btn-text">Portafolio</span>
            <span class="btn-glitch"></span>
          </a>
        </div>
      </div>
      <div class="particles">
        <canvas id="particleCanvas"></canvas>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  @import '../styles/global.css';

  :root {
    --color-bg: #0a1628;
    --color-primary: #00d4ff;
    --color-secondary: #9d4edd;
    --text-main: #ffffff;
    --font-mono: 'Courier New', monospace;
  }

  [data-theme="dark"] {
    --color-bg: #1a0a2e;
    --color-primary: #9d4edd;
    --color-secondary: #00d4ff;
    --text-main: #ffffff;
  }

  body {
    background-color: var(--color-bg);
    color: var(--text-main);
    overflow-x: hidden;
    font-family: var(--font-mono);
  }

  .theme-toggle {
    position: absolute;
    top: 2rem;
    right: 2rem;
    z-index: 100;
    background: var(--bg-secondary, rgba(0, 212, 255, 0.1));
    border: 1px solid var(--color-primary);
    border-radius: 12px;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    color: var(--color-primary);
  }

  [data-theme="dark"] .theme-toggle {
    background: rgba(157, 78, 221, 0.15);
    border-color: rgba(157, 78, 221, 0.5);
    color: #9d4edd;
  }

  .theme-toggle:hover {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 4px rgba(0, 212, 255, 0.2);
  }

  [data-theme="dark"] .theme-toggle:hover {
    border-color: #9d4edd;
    box-shadow: 0 0 0 4px rgba(157, 78, 221, 0.2);
  }

  .moon-icon { display: none; }
  [data-theme="dark"] .sun-icon { display: none; }
  [data-theme="dark"] .moon-icon { display: block; }

  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background: var(--color-bg);
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(0, 212, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 212, 255, 0.05) 1px, transparent 1px);
    background-size: 50px 50px;
    animation: gridMove 20s linear infinite;
  }

  [data-theme="dark"] .grid-bg {
    background-image: 
      linear-gradient(rgba(157, 78, 221, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(157, 78, 221, 0.05) 1px, transparent 1px);
  }

  @keyframes gridMove {
    0% { transform: translate(0, 0); }
    100% { transform: translate(50px, 50px); }
  }

  .content {
    position: relative;
    z-index: 10;
    text-align: center;
  }

  h1 {
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 800;
    letter-spacing: 0.02em;
    color: var(--text-main);
    text-shadow: 4px 4px 8px rgba(0, 20, 40, 0.8);
    position: relative;
    display: block;
    text-align: center;
    line-height: 1.1;
    text-transform: uppercase;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    max-width: 100%;
    padding: 0 1rem;
    box-sizing: border-box;
  }
 
  h1 .line1,
  h1 .line2 {
    display: inline;
    margin: 0;
    color: var(--text-main);
  }
 
  h1 .line2 {
    text-shadow: 4px 4px 8px rgba(0, 20, 40, 0.8);
    margin-top: 0;
    margin-left: 0.2em;
  }

  .subtitle {
    font-size: clamp(1rem, 3vw, 1.5rem);
    letter-spacing: 0.2em;
    color: var(--text-main);
    margin: 2rem 0;
    text-transform: uppercase;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .cta-container {
    display: flex;
    gap: 2rem;
    justify-content: center;
    margin-top: 3rem;
    flex-wrap: wrap;
  }

  .cyber-btn {
    padding: 1rem 3rem;
    font-family: var(--font-mono);
    font-size: 1rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    background: var(--color-primary);
    color: var(--color-bg);
    border: 2px solid var(--color-primary);
    position: relative;
    cursor: pointer;
    transition: all 0.3s ease;
    clip-path: polygon(10% 0, 100% 0, 100% 70%, 90% 100%, 0 100%, 0 30%);
    text-decoration: none;
    display: inline-block;
    font-weight: bold;
  }

  .cyber-btn:hover {
    background: var(--color-bg);
    color: var(--color-primary);
    box-shadow: 0 0 30px var(--color-primary);
  }

  .particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  canvas {
    width: 100%;
    height: 100%;
  }
</style>

<script>
  import gsap from 'gsap';

  const hero = document.querySelector('.hero') as HTMLElement;
  const toggleTheme = document.querySelector('.theme-toggle') as HTMLButtonElement;
  const savedTheme = localStorage.getItem('theme') || 'light';
  hero.dataset.theme = savedTheme;

  toggleTheme?.addEventListener('click', () => {
    const currentTheme = hero.dataset.theme;
    hero.dataset.theme = currentTheme === 'light' ? 'dark' : 'light';
    localStorage.setItem('theme', hero.dataset.theme as string);
  });

  const disintegrateBtn = document.querySelector('.disintegrate') as HTMLAnchorElement;
  disintegrateBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    const content = document.querySelector('.content');
    const particles = document.getElementById('particleCanvas');
    const chars = content?.querySelectorAll('h1, .subtitle, .cta-container');
    
    gsap.to(chars, {
      duration: 0.8,
      scale: 1.5,
      opacity: 0,
      filter: 'blur(20px)',
      stagger: 0.1,
      ease: 'power2.in',
      onComplete: () => {
        window.location.href = '/portfolio';
      }
    });

    if (particles) {
      gsap.to(particles, {
        duration: 0.5,
        opacity: 0,
        scale: 2,
        ease: 'power2.in'
      });
    }
  });

  const canvas = document.getElementById('particleCanvas') as HTMLCanvasElement;
  const ctx = canvas?.getContext('2d');
  if (ctx) {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    const particles: { x: number; y: number; vx: number; vy: number; size: number }[] = [];
    for (let i = 0; i < 100; i++) {
      particles.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        vx: (Math.random() - 0.5) * 0.5,
        vy: (Math.random() - 0.5) * 0.5,
        size: Math.random() * 2 + 1
      });
    }
    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const primaryColor = getComputedStyle(document.documentElement).getPropertyValue('--color-primary').trim() || '#00d4ff';
      const rgb = primaryColor.replace('#', '').match(/.{2}/g)?.map(x => parseInt(x, 16)).join(', ') || '0, 212, 255';
      particles.forEach((p, i) => {
        p.x += p.vx; p.y += p.vy;
        if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
        if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = primaryColor;
        ctx.fill();
        for (let j = i + 1; j < particles.length; j++) {
          const p2 = particles[j];
          const dist = Math.sqrt((p.x - p2.x)**2 + (p.y - p2.y)**2);
          if (dist < 150) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(p2.x, p2.y);
            ctx.strokeStyle = `rgba(${rgb}, ${0.15 * (1 - dist / 150)})`;
            ctx.stroke();
          }
        }
      });
      requestAnimationFrame(animate);
    }
    animate();
  }

  gsap.from('.content > *', {
    y: 50,
    opacity: 0,
    duration: 1,
    stagger: 0.2,
    ease: 'power3.out'
  });
</script>
