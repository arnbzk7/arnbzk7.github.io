<script>
  const page = document.querySelector('.page') as HTMLElement;
  const sidebar = document.querySelector('.sidebar') as HTMLElement;
  const main = document.querySelector('.main') as HTMLElement;
  const toggleTheme = document.querySelector('.theme-toggle') as HTMLButtonElement;
  const toggleSidebar = document.querySelector('.sidebar-toggle') as HTMLButtonElement;

  toggleTheme.addEventListener('click', () => {
    const currentTheme = page.dataset.theme;
    page.dataset.theme = currentTheme === 'light' ? 'dark' : 'light';
    localStorage.setItem('theme', page.dataset.theme);
  });

  toggleSidebar.addEventListener('click', () => {
    sidebar.classList.toggle('collapsed');
    main.classList.toggle('expanded');
  });

  const savedTheme = localStorage.getItem('theme') || 'light';
  page.dataset.theme = savedTheme;

  const navItems = document.querySelectorAll('.nav-item');
  const sections = document.querySelectorAll('.section');

  navItems.forEach((item) => {
    item.addEventListener('click', (e) => {
      e.preventDefault();
      const targetId = (item as HTMLElement).dataset.section;
      const target = document.getElementById(targetId as string);
      
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      navItems.forEach((nav) => nav.classList.remove('active'));
      item.classList.add('active');
    });
  });

  const observerOptions = {
    root: null,
    rootMargin: '-50% 0px -50% 0px',
    threshold: 0
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        navItems.forEach((item) => {
          const itemSection = (item as HTMLElement).dataset.section;
          if (itemSection === id) {
            item.classList.add('active');
          } else {
            item.classList.remove('active');
          }
        });
      }
    });
  }, observerOptions);

  sections.forEach((section) => observer.observe(section));

  const reveals = document.querySelectorAll('.reveal');
  
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry, index) => {
      if (entry.isIntersecting) {
        setTimeout(() => {
          entry.target.classList.add('visible');
        }, index * 100);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

  reveals.forEach((el) => revealObserver.observe(el));

  const copyEmailBtn = document.querySelector('.copy-email-btn') as HTMLButtonElement;
  if (copyEmailBtn) {
    copyEmailBtn.addEventListener('click', async () => {
      const email = copyEmailBtn.dataset.email;
      if (email) {
        try {
          await navigator.clipboard.writeText(email);
          copyEmailBtn.classList.add('copied');
          setTimeout(() => {
            copyEmailBtn.classList.remove('copied');
          }, 2000);
        } catch (err) {
          const textArea = document.createElement('textarea');
          textArea.value = email;
          textArea.style.position = 'fixed';
          textArea.style.left = '-9999px';
          document.body.appendChild(textArea);
          textArea.select();
          document.execCommand('copy');
          document.body.removeChild(textArea);
          copyEmailBtn.classList.add('copied');
          setTimeout(() => {
            copyEmailBtn.classList.remove('copied');
          }, 2000);
        }
      }
    });
  }

  function setupCarousel(carouselId: string) {
    const carouselTrack = document.getElementById(carouselId) as HTMLElement;
    if (!carouselTrack) return;

    let isPaused = false;
    let pauseTimeout: ReturnType<typeof setTimeout>;
    let scrollSpeed = 1;
    let lastX = 0;

    function startAutoScroll() {
      if (!isPaused) return;
      isPaused = false;
      carouselTrack.classList.remove('paused');
    }

    function pauseAutoScroll() {
      if (isPaused) return;
      isPaused = true;
      carouselTrack.classList.add('paused');
      clearTimeout(pauseTimeout);
      pauseTimeout = setTimeout(startAutoScroll, 3000);
    }

    carouselTrack.addEventListener('mousedown', (e) => {
      e.preventDefault();
      pauseAutoScroll();
      lastX = e.clientX;
      
      const startScrollLeft = carouselTrack.scrollLeft;
      let hasDragged = false;

      const onMouseMove = (e: MouseEvent) => {
        const deltaX = e.clientX - lastX;
        if (Math.abs(deltaX) > 5) hasDragged = true;
        carouselTrack.scrollLeft = startScrollLeft - deltaX;
        lastX = e.clientX;
        
        const computedStyle = getComputedStyle(carouselTrack);
        const currentTransform = computedStyle.transform;
        if (currentTransform !== 'none') {
          const matrix = new DOMMatrix(currentTransform);
          matrix.m41 -= deltaX * scrollSpeed;
          carouselTrack.style.transform = `translateX(${matrix.m41}px)`;
        }
      };

      const onMouseUp = () => {
        document.removeEventListener('mousemove', onMouseMove);
        document.removeEventListener('mouseup', onMouseUp);
        
        if (hasDragged) {
          const currentTransform = getComputedStyle(carouselTrack).transform;
          if (currentTransform !== 'none') {
            const matrix = new DOMMatrix(currentTransform);
            carouselTrack.style.transform = '';
            carouselTrack.style.setProperty('--last-offset', matrix.m41.toString());
          }
        }
      };

      document.addEventListener('mousemove', onMouseMove);
      document.addEventListener('mouseup', onMouseUp);
    });

    carouselTrack.addEventListener('touchstart', (e) => {
      pauseAutoScroll();
      lastX = e.touches[0].clientX;
    });

    carouselTrack.addEventListener('touchmove', (e) => {
      const deltaX = e.touches[0].clientX - lastX;
      carouselTrack.scrollLeft -= deltaX;
      lastX = e.touches[0].clientX;
    });

    carouselTrack.addEventListener('touchend', () => {
      pauseTimeout = setTimeout(startAutoScroll, 3000);
    });
  }

  setupCarousel('carouselBackend');
  setupCarousel('carouselFrontend');

  const canvas = document.getElementById('particleCanvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d');

  function getParticleColor() {
    const isDark = document.documentElement.dataset.theme === 'dark';
    return isDark ? 'rgba(96, 165, 250, 0.5)' : 'rgba(37, 99, 235, 0.4)';
  }

  if (ctx) {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    const particles: { x: number; y: number; vx: number; vy: number; size: number }[] = [];
    const particleCount = 50;

    for (let i = 0; i < particleCount; i++) {
      particles.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        vx: (Math.random() - 0.5) * 0.5,
        vy: (Math.random() - 0.5) * 0.5,
        size: Math.random() * 2 + 1
      });
    }

    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      particles.forEach((p, i) => {
        p.x += p.vx;
        p.y += p.vy;

        if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
        if (p.y < 0 || p.y > canvas.height) p.vy *= -1;

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = getParticleColor();
        ctx.fill();

        for (let j = i + 1; j < particles.length; j++) {
          const p2 = particles[j];
          const dx = p.x - p2.x;
          const dy = p.y - p2.y;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < 120) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(p2.x, p2.y);
            ctx.strokeStyle = `rgba(37, 99, 235, ${0.08 * (1 - dist / 120)})`;
            ctx.stroke();
          }
        }
      });

      requestAnimationFrame(animate);
    }

    animate();

    window.addEventListener('resize', () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    });
  }
</script>
