---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title=" Geovanny Peñaloza | Portfolio ">
  <div class="page" data-theme="light">
    <div class="grid-bg"></div>
    <div class="particles">
      <canvas id="particleCanvas"></canvas>
    </div>
    <nav class="sidebar">
      <div class="sidebar-content">
        <a href="#hero" class="nav-item active" data-section="hero">
          <span class="nav-dot"></span>
          <span class="nav-label">Hero</span>
        </a>
        <a href="#about" class="nav-item" data-section="about">
          <span class="nav-dot"></span>
          <span class="nav-label">About Me</span>
        </a>
        <a href="#skills" class="nav-item" data-section="skills">
          <span class="nav-dot"></span>
          <span class="nav-label">Technology Stack</span>
        </a>
        <a href="#experience" class="nav-item" data-section="experience">
          <span class="nav-dot"></span>
          <span class="nav-label">Experience</span>
        </a>
        <a href="#projects" class="nav-item" data-section="projects">
          <span class="nav-dot"></span>
          <span class="nav-label">Projects</span>
        </a>
        <a href="#education" class="nav-item" data-section="education">
          <span class="nav-dot"></span>
          <span class="nav-label">Education</span>
        </a>
      </div>
      <div class="sidebar-footer">
        <button class="theme-toggle" aria-label="Toggle theme">
          <svg class="sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"/>
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
          <svg class="moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
        <button class="sidebar-toggle" aria-label="Toggle sidebar">
          <svg class="arrow-left" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
          <svg class="arrow-right" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>
      </div>
    </nav>

    <main class="main">
      <section id="hero" class="section hero-section">
        <div class="hero-content">
          <span class="badge reveal">Portfolio</span>
          <h1 class="reveal">GEOVANNY PEÑALOZA</h1>
          <p class="role reveal">Full Stack Developer | .NET Core, C#, Flutter | Cloud & SQL</p>
          <p class="description reveal">
            Developer focused on functional solutions and scalable systems. Specialized in .NET, Flutter, and modern architectures.
          </p>
          <div class="location reveal">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span>Ecuador</span>
          </div>
          <div class="social-links reveal">
            <button class="social-btn copy-email-btn" aria-label="Copy email" data-email="geovanny3j@gmail.com">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </button>
            <a href="https://linkedin.com/in/arnbzk/" target="_blank" class="social-btn" aria-label="LinkedIn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                <rect x="2" y="9" width="4" height="12"/>
                <circle cx="4" cy="4" r="2"/>
              </svg>
            </a>
            <a href="https://github.com/geovannypenaloza" target="_blank" class="social-btn" aria-label="GitHub">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
              </svg>
            </a>
            <a href="Cell" class="social-btn" aria-label="Phone">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </a>
          </div>
        </div>
        <div class="hero-visual">
          <div class="profile-image">
            <img id="profileImg" src="/images/perfilportafolio.jpeg" alt="Profile">
            <div class="image-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
              <span>Tu imagen</span>
            </div>
          </div>
          <div class="orb"></div>
          <div class="orb orb-2"></div>
        </div>
      </section>

      <section id="about" class="section">
        <h2 class="section-title reveal">About Me</h2>
        <div class="about-content reveal">
          <p>
            Junior Full Stack Developer with hands-on experience in developing web and mobile applications using .NET (C#), Flutter, and SQL-based systems. Possesses a strong understanding of the complete software development lifecycle, including API design, database management, and modern frontend technologies.
          </p>
          <p>
            Experienced in developing real-world solutions through freelance projects, including a scalable GPS tracking system and a fully customized e-commerce platform. Capable of working independently, managing development processes, and delivering functional, business-oriented systems.
          </p>
          <p>
            Highly motivated to advance into senior software engineering roles, with a focus on continuous learning, emerging technologies, and AI-driven development.
          </p>
        </div>
        <div class="stats-grid reveal">
          <div class="stat-item">
            <span class="stat-number">4+</span>
            <span class="stat-label">Completed Projects</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">1+</span>
            <span class="stat-label">Years of Experience</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">7+</span>
            <span class="stat-label">Technologies</span>
          </div> 
        </div>
      </section>

      <section id="skills" class="section">
        <h2 class="section-title reveal">Technology Stack</h2>
        
        <div class="skills-cards-grid">
          <div class="skill-card reveal">
            <div class="skill-card-header">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="2" y1="12" x2="22" y2="12"/>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
              <h3>Frontend / Mobile & Web </h3>
            </div>
            <div class="skill-list">
              <span class="skill-tag">Flutter</span>
              <span class="skill-tag">Astro</span>              
              <span class="skill-tag">Tailwind CSS</span>              
            </div>
          </div>

          <div class="skill-card reveal">
            <div class="skill-card-header">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                <line x1="8" y1="21" x2="16" y2="21"/>
                <line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
              <h3>Backend</h3>
            </div>
            <div class="skill-list">
              <span class="skill-tag">C#</span>
              <span class="skill-tag">.NET Core</span>              
              <span class="skill-tag">Entity Framework</span>
              <span class="skill-tag">SQL Server</span>
              <span class="skill-tag">PostgreSQL</span>
              <span class="skill-tag">SQL Lite</span>
            </div>
          </div>

          <div class="skill-card reveal">
            <div class="skill-card-header">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
              </svg>
              <h3>Tools</h3>
            </div>
            <div class="skill-list">
              <span class="skill-tag">Git</span>
              <span class="skill-tag">Docker</span>
              <span class="skill-tag">Linux</span>
              <span class="skill-tag">AI-assisted Development</span>              
              <span class="skill-tag">LLM Tooling</span>
            </div>
          </div>
        </div>
      </section>

      <section id="experience" class="section">
        <h2 class="section-title reveal">Experience</h2>
        <div class="timeline">
          <div class="timeline-item reveal">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <span class="timeline-date">Nov 2025 - Present</span>
              <h4>Full Stack Developer</h4>
              <p class="timeline-company">Freelance - Ecuador</p>
              <p class="timeline-desc">
                Designed and developed real-world software solutions including a scalable GPS tracking system with real-time monitoring, alerts, route history, and live map visualization.
Built cross-platform mobile and web applications using Flutter, and contributed to backend development with C# and ABP Framework.
Implemented queue-based, multi-process architectures to handle high concurrency and ensure fault tolerance.
Developed a custom e-commerce platform with advanced UI/UX and integrated Nequi payment system.
              </p>
            </div>
          </div>
          <div class="timeline-item reveal">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <span class="timeline-date">Aug 2024 - Nov 2024</span>
              <h4>IT Support & Systems Intern</h4>
              <p class="timeline-company">Ikiam Amazonian Regional University - Ecuador</p>
              <p class="timeline-desc">
                Managed servers, databases, and internal systems within the IT department. Performed OS installations (Linux/Windows) and system maintenance. Executed SQL-based database tasks and supported infrastructure operations, ensuring system reliability and operational continuity across the university's technology infrastructure.
              </p>
            </div>
          </div>
          <div class="timeline-item reveal">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <span class="timeline-date">Feb 2024 - Aug 2024</span>
              <h4>IT & Systems Intern</h4>
              <p class="timeline-company">Tena Higher Technological Institute - Ecuador</p>
              <p class="timeline-desc">
                Supported deployment of an academic management system for institutional use. Identified and resolved system issues through bug fixing and validation processes. Created comprehensive technical documentation and user manuals to support system adoption and streamline operational workflows.
              </p>
            </div>
          </div>
          <div class="timeline-item reveal">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <span class="timeline-date">Feb 2022 - Aug 2022</span>
              <h4>IT Support Intern</h4>
              <p class="timeline-company">Archidona Municipal Government - Ecuador</p>
              <p class="timeline-desc">
                Implemented and maintained an internal messaging system for institutional communication. Managed system functionality across Windows environments with Linux-based backend infrastructure. Ensured system stability and operational continuity, supporting daily municipal operations and digital transformation initiatives.
              </p>
            </div>
          </div>
          <div class="timeline-item reveal">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <span class="timeline-date">Sep 2021 - Dec 2021</span>
              <h4>IT Systems Intern</h4>
              <p class="timeline-company">Institute of Popular and Solidarity Economy - Ecuador</p>
              <p class="timeline-desc">
                Assisted in system management and internal technical operations. Supported workflow organization and system usage across departments. Delivered digital literacy training to older adults, promoting technology adoption and building confidence in digital tools among diverse audiences.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="projects" class="section">
        <h2 class="section-title reveal">Projects</h2>
        <div class="projects-grid">
          <div class="project-card reveal">
            <div class="project-header">
              <span class="project-icon">📍</span>
              <h4>GPS Tracking System</h4>
            </div>
            <p class="project-desc">
              Developed a scalable GPS tracking system with real-time monitoring, alerts, route history, and live map visualization.
Implemented a multi-process, high-availability architecture supporting thousands of concurrent users.
Built cross-platform web and mobile apps using Flutter, with a C# backend powered by ABP Framework.
Designed a fault-tolerant system isolating user-level failures without impacting overall performance.
            </p>
            <div class="project-tags">
              <span>Flutter</span>
              <span>C#</span>
              <span>ABP Framework</span>
            </div>
            <div class="project-links">
              <a href="#" class="project-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
                </svg>
                GitHub
              </a>
            </div>
          </div>

          <div class="project-card reveal">
            <div class="project-header">
              <span class="project-icon">🛍️</span>
              <h4>Kyomu Space</h4>
            </div>
            <p class="project-desc">
              Built a custom e-commerce platform for a Colombian women-focused store with full product catalog, user profiles, and shopping cart functionality.
Designed an advanced UI/UX and integrated the Nequi payment gateway for secure, seamless transactions.
Delivered a complete end-to-end shopping experience from browsing to checkout.
            </p>
            <div class="project-tags">
              <span>WordPress</span>
              <span>Nequi API</span>
            </div>
            <div class="project-links">
              <a href="https://kyomu.space/" class="project-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                Visit
              </a>
            </div>
          </div>

          <div class="project-card reveal">
            <div class="project-header">
              <span class="project-icon">💻</span>
              <h4>EduCode</h4>
            </div>
            <p class="project-desc">
              Developed a native Android application for structured programming education.
Designed core concept modules with interactive assessments to accelerate learning.
Implemented guided paths, hands-on exercises, and progress tracking.
Enabled scalable, measurable skill development in software fundamentals.
            </p>
            <div class="project-tags">
              <span>Flutter</span>
              <span>Android</span>
            </div>
            <div class="project-links">
              <a href="#" class="project-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                Visit
              </a>
            </div>
          </div>

          <div class="project-card reveal">
            <div class="project-header">
              <span class="project-icon">🎮</span>
              <h4>System Overload Bit</h4>
            </div>
            <p class="project-desc">
              Developed a 2D simulation game combining evasion and precision mechanics with hybrid controls (keyboard and mouse).
Designed a reactive environment where players dodge stochastic entities and capture targets under time pressure.
Implemented algorithmic logic to handle randomness and dynamic gameplay behavior.
Focused on precision, performance, and responsive game mechanics.
            </p>
            <div class="project-tags">
              <span>Python</span>
              <span>Pygame</span>
            </div>
            <div class="project-links">
              <a href="#" class="project-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
                </svg>
                GitHub
              </a>
            </div>
          </div>
        </div>
      </section>

      <section id="education" class="section">
        <h2 class="section-title reveal">Education</h2>
        <div class="education-card reveal">
          <div class="edu-header">
            <span class="edu-icon">🎓</span>
            <div>
              <h4>Technologist in Systems Analysis</h4>
              <p class="edu-institution">Tena Higher Technological Institute</p>
            </div>
          </div>
          <span class="edu-date">2021 - 2024</span>
        </div>

        <div class="languages-card reveal">
          <h4 class="languages-title">Languages</h4>
          <div class="languages-grid">
            <div class="language-item">
              <span class="lang-name">Spanish</span>
              <span class="lang-level">Native</span>
            </div>
            <div class="language-item">
              <span class="lang-name">English</span>
              <span class="lang-level">Basic-Limited</span>
            </div>
          </div>
        </div>

        <div class="additional-info reveal">
          <h4 class="info-title">Additional Information</h4>
          <ul class="info-list">
            <li>Strong interest in Artificial Intelligence integration for software development and workflow optimization</li>
            <li>Focus on clean code, maintainability, and scalable system design</li>
            <li>Continuous learner in software engineering, architecture, and emerging technologies</li>
            <li>Experience promoting technology education and digital literacy across diverse audiences</li>
          </ul>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  :root {
    --bg-primary: #a8d0e6;
    --bg-secondary: #b8dcef;
    --bg-glass: rgba(184, 220, 239, 0.7);
    --text-primary: #1a1a2e;
    --text-secondary: #334155;
    --accent: #0066ff;
    --accent-soft: rgba(0, 102, 255, 0.1);
    --border: rgba(0, 0, 0, 0.1);
    --shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    --shadow-hover: 0 16px 48px rgba(0, 0, 0, 0.12);
    --sidebar-width: 200px;
    --content-padding: 3rem;
  }

  [data-theme="dark"] {
    --bg-primary: #0f0a1a;
    --bg-secondary: #1a1225;
    --bg-glass: rgba(26, 18, 37, 0.8);
    --text-primary: #f0f0f5;
    --text-secondary: #a0a0b0;
    --accent: #9d4edd;
    --accent-soft: rgba(157, 78, 221, 0.15);
    --border: rgba(157, 78, 221, 0.2);
    --shadow: 0 8px 32px rgba(157, 78, 221, 0.1);
    --shadow-hover: 0 16px 48px rgba(157, 78, 221, 0.2);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: var(--bg-primary);
    color: var(--text-primary);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    transition: background 0.4s ease, color 0.4s ease;
  }

  .page {
    min-height: 100vh;
    background: var(--bg-primary);
    transition: background 0.4s ease;
    position: relative;
    overflow: hidden;
  }

  .grid-bg {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(37, 99, 235, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(37, 99, 235, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
    animation: gridMove 20s linear infinite;
    pointer-events: none;
    z-index: 0;
  }

  @keyframes gridMove {
    0% { transform: translate(0, 0); }
    100% { transform: translate(50px, 50px); }
  }

  .particles {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .particles canvas {
    width: 100%;
    height: 100%;
  }

  .sidebar {
    position: fixed;
    right: 0;
    top: 0;
    bottom: 0;
    width: 200px;
    background: var(--bg-glass);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-left: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 2rem 0;
    z-index: 100;
    transition: all 0.4s ease;
  }

  .sidebar.collapsed {
    width: 60px;
  }

  .sidebar.collapsed .nav-label,
  .sidebar.collapsed .sidebar-footer span {
    opacity: 0;
    width: 0;
    overflow: hidden;
  }

  .sidebar.collapsed .nav-item {
    justify-content: center;
    padding: 0.75rem;
  }

  .sidebar-content {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0;
    flex: 1;
    justify-content: center;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1rem;
    border-radius: 0;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.3s ease;
