---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Sobre Mí | Geovanny Peñaloza">
  <section class="about">
    <div class="grid-bg"></div>
    <div class="glitch-overlay" id="glitchOverlay"></div>
    <div class="content">
      <h1 class="glitch" data-text="SOBRE MÍ">SOBRE MÍ</h1>
      
      <div class="about-grid">
        <div class="about-card">
          <h3>Quién Soy</h3>
          <p>Desarrollador full stack especializado en interfaces futuristas y experiencias digitales inmersivas. Combino diseño UI/UX con código para crear experiencias únicas.</p>
        </div>
        
        <div class="about-card">
          <h3>Habilidades</h3>
          <div class="skills">
            <span class="skill-tag">JavaScript</span>
            <span class="skill-tag">TypeScript</span>
            <span class="skill-tag">React</span>
            <span class="skill-tag">Astro</span>
            <span class="skill-tag">Three.js</span>
            <span class="skill-tag">GSAP</span>
            <span class="skill-tag">Node.js</span>
            <span class="skill-tag">Python</span>
          </div>
        </div>
        
        <div class="about-card">
          <h3>Enfoque</h3>
          <p>Creo interfaces que trascienden lo convencional. Cada proyecto es una oportunidad para innovar y push los límites del diseño web.</p>
        </div>
        
        <div class="about-card">
          <h3>Contacto</h3>
          <p>¿Tienes un proyecto en mente? Hablemos y hagámoslo realidad.</p>
          <a href="mailto:geovanny@email.com" class="contact-link">geovanny@email.com</a>
        </div>
      </div>

      <a href="/" class="cyber-btn green back-btn">
        <span class="btn-text">Volver</span>
      </a>
    </div>
    <div class="particles">
      <canvas id="particleCanvas"></canvas>
    </div>
  </section>
</BaseLayout>

<style>
  .about {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 2rem;
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(255, 0, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 0, 255, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
    animation: gridMove 20s linear infinite;
  }

  @keyframes gridMove {
    0% { transform: translate(0, 0); }
    100% { transform: translate(50px, 50px); }
  }

  .glitch-overlay {
    position: fixed;
    inset: 0;
    background: var(--color-secondary);
    opacity: 0;
    pointer-events: none;
    z-index: 100;
  }

  .content {
    position: relative;
    z-index: 10;
    text-align: center;
    width: 100%;
    max-width: 1000px;
  }

  h1 {
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 900;
    letter-spacing: 0.3em;
    color: var(--color-secondary);
    text-shadow: 
      0 0 10px var(--color-secondary),
      0 0 40px var(--color-secondary);
    margin-bottom: 3rem;
  }

  .about-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .about-card {
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid var(--color-secondary);
    padding: 1.5rem;
    position: relative;
    transition: all 0.3s ease;
    clip-path: polygon(0 0, 100% 0, 100% 85%, 85% 100%, 0 100%);
  }

  .about-card:hover {
    transform: translateY(-5px) scale(1.02);
    box-shadow: 0 0 30px rgba(255, 0, 255, 0.4);
  }

  .about-card h3 {
    color: var(--color-secondary);
    font-size: 1.2rem;
    margin-bottom: 1rem;
    font-family: var(--font-mono);
  }

  .about-card p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .skill-tag {
    background: rgba(255, 0, 255, 0.15);
    border: 1px solid var(--color-secondary);
    padding: 0.3rem 0.6rem;
    font-size: 0.7rem;
    color: var(--color-secondary);
    font-family: var(--font-mono);
  }

  .contact-link {
    display: inline-block;
    margin-top: 1rem;
    color: var(--color-secondary);
    text-decoration: underline;
    font-family: var(--font-mono);
  }

  .back-btn {
    display: inline-block;
    text-decoration: none;
  }

  .particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  canvas {
    width: 100%;
    height: 100%;
  }
</style>

<script>
  import gsap from 'gsap';
  
  const canvas = document.getElementById('particleCanvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d');
  
  if (ctx) {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    
    const particles: { x: number; y: number; vx: number; vy: number; size: number }[] = [];
    const particleCount = 80;
    
    for (let i = 0; i < particleCount; i++) {
      particles.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        vx: (Math.random() - 0.5) * 0.5,
        vy: (Math.random() - 0.5) * 0.5,
        size: Math.random() * 2 + 1
      });
    }
    
    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      
      particles.forEach((p) => {
        p.x += p.vx;
        p.y += p.vy;
        
        if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
        if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
        
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255, 0, 255, 0.5)';
        ctx.fill();
      });
      
      requestAnimationFrame(animate);
    }
    
    animate();
  }
  
  gsap.from('.content > *', {
    y: 50,
    opacity: 0,
    duration: 1,
    stagger: 0.15,
    ease: 'power3.out'
  });

  gsap.from('.about-card', {
    x: (i) => (i % 2 === 0 ? -100 : 100),
    opacity: 0,
    duration: 0.8,
    stagger: 0.1,
    delay: 0.5,
    ease: 'power2.out'
  });
</script>
