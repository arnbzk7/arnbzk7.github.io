            <div class="carousel-track" id="carouselFrontend">
              <div class="tech-card">
                <span class="tech-icon">🎨</span>
                <span class="tech-name">HTML5</span>
              </div>
              <div class="tech-card">
                <span class="tech-icon">🎨</span>
                <span class="tech-name">CSS3</span>
              </div>
              <div class="tech-card">
                <span class="tech-icon">🔧</span>
                <span class="tech-name">Tailwind</span>
              </div>
              <div class="tech-card">
                <span class="tech-icon">🚀</span>
                <span class="tech-name">Astro</span>
              </div>
              <div class="tech-card">
                <span class="tech-icon">📱</span>
                <span class="tech-name">Flutter</span>
              </div>
              <div class="tech-card">
                <span class="tech-icon">📱</span>
                <span class="tech-name">Dart</span>
              </div>
              <div class="tech-card">
                <span class="tech-icon">🛠️</span>
                <span class="tech-name">Git</span>
              </div>
              <div class="tech-card">
                <span class="tech-icon">🐳</span>
                <span class="tech-name">Docker</span>
              </div>
              <div class="tech-card">
                <span class="tech-icon">🐧</span>
                <span class="tech-name">Linux</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="experience" class="section">
        <h2 class="section-title reveal">Experiencia</h2>
        <div class="timeline">
          <div class="timeline-item reveal">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <span class="timeline-date">Nov 2025 - Presente</span>
              <h4>Full Stack Developer</h4>
              <p class="timeline-company">Freelance - Ecuador</p>
              <p class="timeline-desc">
                Diseno y desarrollo de soluciones de software reales, incluyendo sistemas GPS y plataformas e-commerce.
                Sistema GPS escalable con monitoreo en tiempo real, alertas y visualizacion de rutas.
                Aplicaciones moviles y web usando Flutter.
              </p>
            </div>
          </div>
          <div class="timeline-item reveal">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <span class="timeline-date">Ago 2024 - Nov 2024</span>
              <h4>IT Support & Systems Intern</h4>
              <p class="timeline-company">Universidad IKIAM Amazonica Regional - Ecuador</p>
              <p class="timeline-desc">
                Gestion de servidores, bases de datos y sistemas internos.
                Instalacion de sistemas operativos (Linux/Windows) y mantenimiento.
                Tareas de bases de datos SQL y operaciones de infraestructura.
              </p>
            </div>
          </div>
          <div class="timeline-item reveal">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <span class="timeline-date">Feb 2024 - Ago 2024</span>
              <h4>IT & Systems Intern</h4>
              <p class="timeline-company">Instituto Superior Tecnológico Tena - Ecuador</p>
              <p class="timeline-desc">
                Apoyo en despliegue de sistema de gestion academica.
                Identificacion y resolucion de problemas de sistema (bug fixing).
                Creacion de documentacion tecnica y manuales de usuario.
              </p>
            </div>
          </div>
          <div class="timeline-item reveal">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <span class="timeline-date">Feb 2022 - Ago 2022</span>
              <h4>IT Support Intern</h4>
              <p class="timeline-company">Gobierno Municipal de Archidona - Ecuador</p>
              <p class="timeline-desc">
                Implementacion y mantenimiento de sistema de mensajeria interna.
                Gestion de funcionalidad en entornos Windows con backend Linux.
                Aseguramiento de estabilidad y continuidad operacional.
              </p>
            </div>
          </div>
          <div class="timeline-item reveal">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <span class="timeline-date">Sep 2021 - Dic 2021</span>
              <h4>IT Systems Intern</h4>
              <p class="timeline-company">Instituto de Economia Popular y Solidaria - Ecuador</p>
              <p class="timeline-desc">
                Asistencia en gestion de sistemas y operaciones tecnicas internas.
                Organizacion de flujos de trabajo y uso de sistemas.
                Capacitacion en digital literacy para adultos mayores.
              </p>
            </div>
          </div>
        </div>
      </section>

