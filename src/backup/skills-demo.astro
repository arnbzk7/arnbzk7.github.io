---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Portfolio | Geovanny Peñaloza">
  <div class="page" data-theme="light">
    <nav class="sidebar">
      <div class="sidebar-content">
        <a href="#hero" class="nav-item active" data-section="hero">
          <span class="nav-dot"></span>
          <span class="nav-label">Inicio</span>
        </a>
        <a href="#about" class="nav-item" data-section="about">
          <span class="nav-dot"></span>
          <span class="nav-label">Sobre Mi</span>
        </a>
        <a href="#skills" class="nav-item" data-section="skills">
          <span class="nav-dot"></span>
          <span class="nav-label">Skills</span>
        </a>
        <a href="#experience" class="nav-item" data-section="experience">
          <span class="nav-dot"></span>
          <span class="nav-label">Experiencia</span>
        </a>
        <a href="#projects" class="nav-item" data-section="projects">
          <span class="nav-dot"></span>
          <span class="nav-label">Proyectos</span>
        </a>
        <a href="#education" class="nav-item" data-section="education">
          <span class="nav-dot"></span>
          <span class="nav-label">Educacion</span>
        </a>
        <a href="#contact" class="nav-item" data-section="contact">
          <span class="nav-dot"></span>
          <span class="nav-label">Contacto</span>
        </a>
      </div>
      <div class="sidebar-footer">
        <button class="theme-toggle" aria-label="Toggle theme">
          <svg class="sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"/>
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
          <svg class="moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
        <button class="sidebar-toggle" aria-label="Toggle sidebar">
          <svg class="arrow-left" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
          <svg class="arrow-right" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>
      </div>
    </nav>

    <main class="main">
      <section id="hero" class="section hero-section">
        <div class="hero-content">
          <span class="badge reveal">Portfolio</span>
          <h1 class="reveal">Geovanny Peñaloza</h1>
          <p class="role reveal">Full Stack Developer</p>
          <p class="description reveal">
            Desarrollador con enfoque en soluciones funcionales y sistemas escalables. 
            Especializado en .NET, Flutter y arquitecturas modernas.
          </p>
          <div class="location reveal">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span>Tena, Ecuador</span>
          </div>
          <div class="social-links reveal">
            <a href="https://linkedin.com/in/arnbzk/" target="_blank" class="social-btn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                <rect x="2" y="9" width="4" height="12"/>
                <circle cx="4" cy="4" r="2"/>
              </svg>
            </a>
            <a href="https://github.com/geovannypenaloza" target="_blank" class="social-btn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
              </svg>
            </a>
          </div>
        </div>
        <div class="hero-visual">
          <div class="orb"></div>
          <div class="orb orb-2"></div>
        </div>
      </section>

      <section id="about" class="section">
        <h2 class="section-title reveal">Sobre Mi</h2>
        <div class="about-content reveal">
          <p>
            Junior Full Stack Developer con experiencia practica en el desarrollo de aplicaciones web y moviles 
            utilizando .NET (C#), Flutter y sistemas basados en SQL. Fuerte comprension del ciclo de vida 
            completo del desarrollo de software, incluyendo diseno de API, gestion de bases de datos y 
            tecnologias frontend modernas.
          </p>
          <p>
            Experiencia desarrollando soluciones reales a traves de proyectos freelance, incluyendo un sistema 
            de seguimiento GPS escalable y una plataforma de e-commerce completamente personalizada. 
            Capaz de trabajar de forma independiente, gestionar procesos de desarrollo y entregar sistemas 
            funcionales orientados a negocios.
          </p>
          <p>
            Altamente motivado para crecer en roles avanzados de ingenieria de software, con enfoque en 
            aprendizaje continuo, tecnologias emergentes y desarrollo impulsado por IA.
          </p>
        </div>
        <div class="stats-grid reveal">
          <div class="stat-item">
            <span class="stat-number">4+</span>
            <span class="stat-label">Proyectos Completados</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">3</span>
            <span class="stat-label">Anos de Experiencia</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">15+</span>
            <span class="stat-label">Tecnologias</span>
          </div>
        </div>
      </section>

      <section id="skills" class="section">
        <h2 class="section-title reveal">Stack Tecnologico</h2>
        
        <div class="skills-carousel-group">
          <div class="carousel-header">
            <span class="carousel-label">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                <line x1="8" y1="21" x2="16" y2="21"/>
                <line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
              Backend
            </span>
          </div>
          <div class="carousel-container reveal">
            <div class="carousel-track" id="carouselBackend">
              <div class="tech-card">
                <span class="tech-icon">💻</span>
                <span class="tech-name">C#</span>
              </div>
              <div class="tech-card">
                <span class="tech-icon">⚡</span>
                <span class="tech-name">.NET Core</span>
              </div>
              <div class="tech-card">
                <span class="tech-icon">🌐</span>
                <span class="tech-name">ASP.NET</span>
              </div>
              <div class="tech-card">
                <span class="tech-icon">🗄️</span>
                <span class="tech-name">Entity Framework</span>
              </div>
              <div class="tech-card">
                <span class="tech-icon">🗄️</span>
                <span class="tech-name">SQL Server</span>
              </div>
              <div class="tech-card">
                <span class="tech-icon">🗄️</span>
                <span class="tech-name">PostgreSQL</span>
              </div>
              <div class="tech-card">
                <span class="tech-icon">🤖</span>
                <span class="tech-name">Local AI</span>
              </div>
              <div class="tech-card">
                <span class="tech-icon">🤖</span>
                <span class="tech-name">Claude Code</span>
              </div>
              <div class="tech-card">
                <span class="tech-icon">🤖</span>
                <span class="tech-name">Open Code</span>
              </div>
            </div>
          </div>
        </div>

        <div class="skills-carousel-group">
          <div class="carousel-header">
            <span class="carousel-label">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="2" y1="12" x2="22" y2="12"/>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
