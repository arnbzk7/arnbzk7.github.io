<style>
  :root {
    --bg-primary: #f8f8fa;
    --bg-secondary: #ffffff;
    --bg-glass: rgba(255, 255, 255, 0.7);
    --text-primary: #1d1d1f;
    --text-secondary: #6e6e73;
    --accent: #00d4ff;
    --accent-soft: rgba(0, 212, 255, 0.1);
    --border: rgba(0, 0, 0, 0.06);
    --shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    --shadow-hover: 0 16px 48px rgba(0, 0, 0, 0.12);
    --sidebar-width: 220px;
  }

  [data-theme="dark"] {
    --bg-primary: #0f0a1a;
    --bg-secondary: #1a1225;
    --bg-glass: rgba(26, 18, 37, 0.8);
    --text-primary: #f0f0f5;
    --text-secondary: #a0a0b0;
    --accent: #9d4edd;
    --accent-soft: rgba(157, 78, 221, 0.15);
    --border: rgba(157, 78, 221, 0.2);
    --shadow: 0 8px 32px rgba(157, 78, 221, 0.1);
    --shadow-hover: 0 16px 48px rgba(157, 78, 221, 0.2);
