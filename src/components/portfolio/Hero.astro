---
const personalInfo = {
  name: "Geovanny Peñaloza",
  role: "Full Stack Developer | .NET Core, C#, Flutter | Cloud & SQL",
  description: "Developer focused on functional solutions and scalable systems. Specialized in .NET, Flutter, and modern architectures.",
  location: "Ecuador",
  email: "ageovannyp@hotmail.com",
  linkedin: "https://linkedin.com/in/arnbzk/",
  github: "https://github.com/geovannypenaloza",
  phone: "+593995301052"
};
---

<section id="hero" class="section hero-section">
  <div class="hero-content">
    <span class="badge reveal">Portfolio</span>
    <h1 class="reveal">{personalInfo.name}</h1>
    <p class="role reveal">{personalInfo.role}</p>
    <p class="description reveal">{personalInfo.description}</p>
    <div class="location reveal">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
      <span>{personalInfo.location}</span>
    </div>
    <div class="social-links reveal">
      <a href={`mailto:${personalInfo.email}`} class="social-btn" aria-label="Email">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
      </a>
      <a href={personalInfo.linkedin} target="_blank" class="social-btn" aria-label="LinkedIn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
          <rect x="2" y="9" width="4" height="12"/>
          <circle cx="4" cy="4" r="2"/>
        </svg>
      </a>
      <a href={personalInfo.github} target="_blank" class="social-btn" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
        </svg>
      </a>
      <a href={`tel:${personalInfo.phone}`} class="social-btn" aria-label="Phone">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
      </a>
    </div>
  </div>
  <div class="hero-visual">
    <div class="profile-image">
      <img id="profileImg" src="/images/perfilportafolio.jpeg" alt="Profile">
      <div class="image-placeholder">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
        <span>Tu imagen</span>
      </div>
    </div>
    <div class="orb"></div>
    <div class="orb orb-2"></div>
  </div>
</section>