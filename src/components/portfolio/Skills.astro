---
const skillGroups = [
  {
    title: "Frontend / Mobile & Web",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="10"/>
      <line x1="2" y1="12" x2="22" y2="12"/>
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
    </svg>`,
    skills: ["Flutter", "Astro", "Tailwind CSS"]
  },
  {
    title: "Backend",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
      <line x1="8" y1="21" x2="16" y2="21"/>
      <line x1="12" y1="17" x2="12" y2="21"/>
    </svg>`,
    skills: ["C#", ".NET Core", "Entity Framework", "SQL Server", "PostgreSQL", "SQL Lite"]
  },
  {
    title: "Tools",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
    </svg>`,
    skills: ["Git", "Docker", "Linux", "AI-assisted Development", "LLM Tooling"]
  }
];
---

<section id="skills" class="section">
  <h2 class="section-title reveal">Technology Stack</h2>
  <div class="skills-cards-grid">
    {skillGroups.map(group => (
      <div class="skill-card reveal">
        <div class="skill-card-header">
          <Fragment set:html={group.icon} />
          <h3>{group.title}</h3>
        </div>
        <div class="skill-list">
          {group.skills.map(skill => <span class="skill-tag">{skill}</span>)}
        </div>
      </div>
    ))}
  </div>
</section>